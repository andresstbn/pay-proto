{
  "name": "backend-functions",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "pnpm run build && node --test \"lib/auth/__tests__/*.test.js\" \"lib/groups/__tests__/*.test.js\"",
    "test:coverage": "pnpm run build && node --test --experimental-test-coverage --test-coverage-lines=90 --test-coverage-functions=90 --test-coverage-branches=90 \"lib/auth/__tests__/*.test.js\" \"lib/groups/__tests__/*.test.js\"",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "private": true
}
