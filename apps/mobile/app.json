{
  "expo": {
    "name": "EricPay",
    "slug": "ericpay",
    "scheme": "ericpay",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B1436",
          "image": "./assets/splash-icon.png",
          "imageWidth": 180,
          "resizeMode": "contain"
        }
      ],
      "expo-asset",
      "expo-web-browser",
      "react-native-nitro-google-signin",
      "expo-apple-authentication",
      [
        "expo-media-library",
        {
          "photosPermission": false,
          "savePhotosPermission": "Permitir que EricPay guarde tu código QR en Fotos.",
          "granularPermissions": []
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.andresstbn.ericpay"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.andresstbn.ericpay"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a2af5575-f404-43c8-ae91-f3031290ca24"
      }
    }
  }
}
