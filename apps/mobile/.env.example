# Configuración de Firebase para EricPay (Fase 1)
# Copia este archivo a `.env` y rellena con los valores de tu Web App en Firebase Console.

EXPO_PUBLIC_FIREBASE_API_KEY=tu_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=tu_proyecto
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=tu_proyecto.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=tu_messaging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=tu_app_id

# OAuth social para development builds. Son identificadores públicos de cliente;
# las claves privadas y secretos permanecen en Google/Meta/Apple/Firebase/EAS.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=tu_cliente_web.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=tu_cliente_ios.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=tu_cliente_android.apps.googleusercontent.com
EXPO_PUBLIC_FACEBOOK_APP_ID=tu_facebook_app_id
